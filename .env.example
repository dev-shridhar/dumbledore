# ===========================================
# Dumbledore Bot - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# For FPS.ms deployment, set these in the panel

# Required: Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Required: Bot Username (without @)
BOT_USERNAME=your_bot_username_here

# LLM Configuration
# Option 1: Ollama (local, optional)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Option 2: Groq API (recommended for FPS.ms)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Bot Settings
LLM_TIMEOUT=30
MAX_HISTORY=50
CONTEXT_MESSAGES=20

# Admin Settings (comma-separated Telegram user IDs)
ADMIN_USER_IDS=
